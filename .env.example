# Discord Bot Token
DISCORD_TOKEN=your_bot_token_here

# Discord Server/Guild ID
GUILD_ID=your_guild_id_here

# Map Voting Channel ID
MAP_VOTE_CHANNEL_ID=your_channel_id_here

# Admin Control Channel ID (where control panel will be)
ADMIN_CHANNEL_ID=your_admin_channel_id_here

# CRCON API Configuration
CRCON_API_URL=https://your-crcon-url.com
CRCON_API_TOKEN=your_crcon_api_token_here

# Optional: Multiple servers
# CRCON_API_URL_2=https://your-crcon-url-2.com
# CRCON_API_TOKEN_2=your_crcon_api_token_2_here
# MAP_VOTE_CHANNEL_ID_2=your_channel_id_2_here
